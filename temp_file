33:// Telegram authentication verification
34:function verifyTelegramData(initData) {
35:  const BOT_TOKEN = process.env.TELEGRAM_BOT_TOKEN;
36:  if (!BOT_TOKEN) {
37:    console.error('TELEGRAM_BOT_TOKEN is not set in environment variables');
38:    return null;
39:  }
40:
41:  try {
42:    const params = new URLSearchParams(initData);
43:    const hash = params.get('hash');
44:    if (!hash) {
45:      console.error('No hash found in Telegram init data');
46:      return null;
47:    }
48:
49:    params.delete('hash');
50:
51:    const dataCheckString = Array.from(params.entries())
52:      .sort(([a], [b]) => a.localeCompare(b))
53:      .map(([key, value]) => `${key}=${value}`)
54:      .join('\n');
55:
56:    const secretKey = crypto.createHmac('sha256', 'WebAppData')
57:      .update(BOT_TOKEN)
58:      .digest();
59:
60:    const computedHash = crypto.createHmac('sha256', secretKey)
61:      .update(dataCheckString)
62:      .digest('hex');
63:
64:    if (computedHash !== hash) {
65:      console.error('Telegram auth hash verification failed');
66:      return null;
67:    }
68:
69:    const userParam = params.get('user');
70:    if (!userParam) {
71:      console.error('No user parameter found in Telegram init data');
72:      return null;
73:    }
74:
75:    return JSON.parse(decodeURIComponent(userParam));
76:  } catch (error) {
77:    console.error('Telegram verification error:', error);
78:    return null;
79:  }
80:}
