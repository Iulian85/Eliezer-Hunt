85:// Check rate limit for a user and action
86:function checkRateLimit(userId, action, maxRequests = 10, windowMs = 60000) {
87:  const key = `${userId}:${action}`;
88:  const now = Date.now();
89:  const windowStart = now - windowMs;
90:
91:  const limit = rateLimits.get(key);
92:
93:  if (!limit || limit.windowStart < windowStart) {
94:    // Reset the rate limit
95:    rateLimits.set(key, { count: 1, windowStart: now });
96:    return true;
97:  }
98:
99:  if (limit.count >= maxRequests) {
100:    return false; // Rate limit exceeded
101:  }
102:
103:  // Increment the count
104:  rateLimits.set(key, { count: limit.count + 1, windowStart: now });
105:  return true;
106:}
